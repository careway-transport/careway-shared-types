# ============================================================
# CareWay — Variables d'environnement
# Copier en .env (jamais committer .env)
# ============================================================

# Node
NODE_ENV=development  # development | test | production

# ---- BASE DE DONNÉES ----------------------------------------
DATABASE_URL=mysql://careway:password@localhost:3306/careway_dev
# Production : récupérer dans hPanel Hostinger > Databases

# ---- AUTH — CLERK -------------------------------------------
# Dashboard : https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Webhook Clerk → backend
CLERK_WEBHOOK_SECRET=whsec_...

# ---- EVENTS — UPSTASH REDIS ---------------------------------
# Dashboard : https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
# Pour BullMQ (connexion directe Redis)
REDIS_URL=rediss://default:token@xxxx.upstash.io:6379

# ---- MONITORING — SENTRY ------------------------------------
# Dashboard : https://careway.sentry.io/
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/xxxx
SENTRY_ORG=careway
SENTRY_PROJECT=careway-api
SENTRY_AUTH_TOKEN=sntrys_...

# ---- LOGS — BETTER STACK ------------------------------------
# Dashboard : https://logs.betterstack.com/
BETTER_STACK_SOURCE_TOKEN=...

# ---- MAIL — RESEND ------------------------------------------
# Dashboard : https://resend.com/
RESEND_API_KEY=re_...
MAIL_FROM=noreply@carewaytransport.fr

# ---- STORAGE — CLOUDFLARE R2 --------------------------------
# Dashboard : https://dash.cloudflare.com/
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=careway-documents
R2_PUBLIC_URL=https://documents.carewaytransport.fr

# ---- API GATEWAY FHIR ---------------------------------------
API_PORT=3001
API_PREFIX=/fhir/r4
GATEWAY_SECRET=...  # secret interne inter-services (JWT HS256)

# ---- HMAC QR CODES ------------------------------------------
QR_HMAC_SECRET=...  # min 32 chars, générer avec : openssl rand -hex 32
QR_TTL_SECONDS=86400  # 24h par défaut

# ---- CARTOGRAPHIE (optionnel Phase 2) -----------------------
# GOOGLE_MAPS_API_KEY=...   # ou OpenRouteService (gratuit)
# ORS_API_KEY=...

# ---- SMOKE TESTS (CI prod) ----------------------------------
SMOKE_USER_EMAIL=smoke@carewaytransport.fr
SMOKE_USER_PASSWORD=...

# ---- URLS ---------------------------------------------------
FRONTEND_URL=https://carewaytransport.fr
API_URL=https://api.carewaytransport.fr
