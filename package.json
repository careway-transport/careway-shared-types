{
  "name": "@careway-transport/shared-types",
  "version": "0.1.0",
  "description": "Types TypeScript FHIR R4 et types métier partagés — CareWay",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fhir": {
      "require": "./dist/fhir/index.js",
      "types": "./dist/fhir/index.d.ts"
    },
    "./careway": {
      "require": "./dist/careway/index.js",
      "types": "./dist/careway/index.d.ts"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
